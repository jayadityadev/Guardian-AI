# Guardian AI — Environment Variables
# Copy this to .env and fill in your keys

# LLM Inference (for flag extraction in analyse.py)
GROQ_API_KEY=<GROQ_API_KEY>
NVIDIA_API_KEY=<NVIDIA_API_KEY>

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+psycopg2://user:pass@host/dbname?sslmode=require

# Optional: Remote ML inference (e.g., Modal deployment)
# ML_API_URL=https://your-modal-app.modal.run/infer
# ML_API_KEY=optional_bearer_token

# Whisper STT model size
WHISPER_MODEL=base
